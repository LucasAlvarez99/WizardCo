# Copiá este archivo a ".env" (sin ".example") y completá con tus datos reales.
# Nunca subas el archivo ".env" real a GitHub — ya está en .gitignore.

# Access Token de Mercado Pago (Panel de Desarrolladores → Tus integraciones
# → tu aplicación → Credenciales). Arrancá con las de PRUEBA (TEST-...) y
# pasá a las de PRODUCCIÓN (APP_USR-...) recién cuando todo funcione.
MP_ACCESS_TOKEN=TEST-000000000000-000000-00000000000000000000000000000000-000000000

# Puerto donde corre este backend.
PORT=4000

# URL pública donde corre ESTE backend (sin barra final), para que Mercado
# Pago pueda mandar el webhook de confirmación de pago. En local no hace
# falta (podés usar ngrok para probarlo); en producción, la URL real de
# donde lo despliegues (Render, Railway, etc.).
PUBLIC_URL=
